            {
              "type": "custom:button-card",
              "entity": "automation.hms_1600_ecreteur_1100w_anti_surtension",
              "name": "[[[\n  if (entity.state === 'off') return 'Écrêteur ❌ ÉTEINT';\n  const limit = parseFloat(hass.states['number.hms_1600_limit_nonpersistent_absolute']?.state || 1600);\n  return limit < 1600 ? 'Écrêteur ⚠️ ACTIF' : 'Écrêteur (Surveillance)';\n]]]\n",
              "show_name": true,
              "show_icon": true,
              "show_label": true,
              "icon": "[[[\n  if (entity.state === 'off') return 'mdi:shield-off';\n  const limit = parseFloat(hass.states['number.hms_1600_limit_nonpersistent_absolute']?.state || 1600);\n  return limit < 1600 ? 'mdi:shield-alert' : 'mdi:shield-sun';\n]]]\n",
              "label": "[[[\n  const limit = parseFloat(hass.states['number.hms_1600_limit_nonpersistent_absolute']?.state || 1600);\n  const voltage = parseFloat(hass.states['sensor.hms_1600_voltage']?.state || 0);\n  const power = parseFloat(hass.states['sensor.hms_1600_power']?.state || 0);\n  const isEcreting = limit < 1600;\n  const status = isEcreting ? `⚠️ LIMITE : ${limit} W` : '✅ Inactif';\n  return `Tension : ${voltage.toFixed(1)} V\\nProd : ${power.toFixed(0)} W\\n${status}`;\n]]]\n",
              "styles": {
                "card": [
                  {
                    "background": "[[[\n  if (entity.state === 'off') return 'linear-gradient(135deg, #37415122, #1f293722)';\n  const limit = parseFloat(hass.states['number.hms_1600_limit_nonpersistent_absolute']?.state || 1600);\n  return limit < 1600\n    ? 'linear-gradient(135deg, #f59e0b22, #ef444422)'\n    : 'linear-gradient(135deg, #10b98111, #05966911)';\n]]]\n"
                  },
                  {
                    "border": "[[[\n  if (entity.state === 'off') return '1px solid #4b5563';\n  const limit = parseFloat(hass.states['number.hms_1600_limit_nonpersistent_absolute']?.state || 1600);\n  return limit < 1600 ? '2px solid #ef4444' : '1px solid #10b981';\n]]]\n"
                  },
                  {
                    "border-radius": "16px"
                  },
                  {
                    "padding": "12px"
                  }
                ],
                "icon": [
                  {
                    "color": "[[[\n  if (entity.state === 'off') return '#6b7280';\n  const limit = parseFloat(hass.states['number.hms_1600_limit_nonpersistent_absolute']?.state || 1600);\n  return limit < 1600 ? '#f59e0b' : '#10b981';\n]]]\n"
                  },
