          "type": "vertical-stack",
          "cards": [
            {
              "type": "markdown",
              "content": "## ⚡ SolarFlow 800 Plus\n"
            },
            {
              "type": "glance",
              "show_name": true,
              "show_icon": true,
              "show_state": true,
              "entities": [
                {
                  "entity": "sensor.solarflow_800_plus_electric_level",
                  "name": "Batterie",
                  "icon": "mdi:battery"
                },
                {
                  "entity": "sensor.solarflow_800_plus_bat_in_out",
                  "name": "Puissance",
                  "icon": "mdi:lightning-bolt"
                },
                {
                  "entity": "sensor.solarflow_800_plus_hyper_tmp",
                  "name": "Temp. SolarFlow",
                  "icon": "mdi:thermometer"
                },
                {
                  "entity": "sensor.ab2000_06618_max_temp",
                  "name": "Temp. Batterie",
                  "icon": "mdi:thermometer"
                }
              ]
            },
            {
              "type": "entities",
