              ]
            },
            {
              "type": "entities",
              "title": "🔋 Décharge (0–800 W)",
              "entities": [
                {
                  "entity": "input_select.solarflow_limite_decharge",
                  "name": "Limite décharge",
                  "icon": "mdi:battery-arrow-down"
                }
              ]
            }
          ]
        },
        {
          "type": "energy-date-selection"
        },
        {
          "type": "custom:button-card",
          "entity": "input_boolean.simulation_chauffe_eau_solaire",
          "name": "Chauffe-eau solaire",
          "show_state": true,
          "show_label": true,
          "icon": "mdi:water-boiler-off",
          "label": "[[[\n  const prod = parseFloat(hass.states['sensor.total_solaire']?.state || 0);\n  const sigma = parseFloat(hass.states['sensor.solaire_stabilite_stats']?.state || 0);\n  const taux = hass.states['sensor.chauffe_eau_opportunite_stats']?.state;\n  const tauxStr = (taux && taux !== 'unknown' && taux !== 'unavailable') ? `fiab. ${parseFloat(taux).toFixed(0)}%` : 'fiab. --';\n  const motif = hass.states['binary_sensor.lancement_chauffe_eau_opportun']\n                ?.attributes?.motif_blocage || '';\n  return `${prod} W · σ=${sigma} W · ${tauxStr}\\n${motif}`;\n]]]\n",
          "styles": {
            "card": [
              {
                "background": "[[[\n  return entity.state === 'on'\n    ? 'linear-gradient(135deg, #f59e0b22, #10b98122)'\n    : 'linear-gradient(135deg, #64748b11, #94a3b811)';\n]]]\n"
              },
              {
                "border": "[[[\n  return entity.state === 'on'\n    ? '2px solid #10b981' : '2px solid #94a3b8';\n]]]\n"
              },
              {
                "border-radius": "16px"
              },
              {
                "padding": "16px"
              }
            ],
            "icon": [
              {
                "color": "[[[\n  return entity.state === 'on' ? '#f59e0b' : '#94a3b8';\n]]]\n"
              },
              {
                "width": "48px"
              }
            ],
            "name": [
              {
                "font-weight": "bold"
              },
              {
                "font-size": "14px"
              }
            ],
            "label": [
              {
                "font-size": "11px"
              },
              {
                "white-space": "pre-line"
              },
              {
                "color": "var(--secondary-text-color)"
              }
            ]
          },
          "state": [
            {
              "value": "on",
              "icon": "mdi:water-boiler",
              "name": "Chauffe-eau ✅ EN MARCHE"
            },
            {
              "value": "off",
              "icon": "mdi:water-boiler-off",
              "name": "Chauffe-eau ⏸ EN VEILLE"
            }
          ]
        },
